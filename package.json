{
  "name": "fc-polotsk",
  "version": "0.1.0",
  "private": true,
  "description": "FC Polotsk — official football club website monorepo (web + studio).",
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm --filter @fc-polotsk/web dev",
    "build": "pnpm --filter @fc-polotsk/web build",
    "start": "pnpm --filter @fc-polotsk/web start",
    "studio": "pnpm --filter @fc-polotsk/studio dev",
    "studio:build": "pnpm --filter @fc-polotsk/studio build",
    "studio:deploy": "pnpm --filter @fc-polotsk/studio deploy",
    "studio:seed": "pnpm --filter @fc-polotsk/studio seed",
    "lint": "pnpm -r --parallel lint",
    "typecheck": "pnpm -r --parallel typecheck"
  }
}
