# Sanity Studio — local dev config.
# Скопируй в apps/studio/.env.local и заполни. Файл .env.local в .gitignore.

# Project ID из sanity.io/manage → ваш проект → Settings.
SANITY_STUDIO_PROJECT_ID=

# Обычно "production". Создаётся при первом запуске Studio или в sanity.io/manage.
SANITY_STUDIO_DATASET=production

# Write-токен (Editor permissions) для seed-скрипта.
# sanity.io/manage → API → Tokens → Add API token.
# НЕ КОММИТЬ. Если светится — реврлируй и пересоздай.
SANITY_STUDIO_WRITE_TOKEN=
